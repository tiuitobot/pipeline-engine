{
  "project_name": "pipeline-engine",
  "description": "Generic domain-agnostic multi-agent pipeline engine extracted from var-cambio-icms",
  "language": "python",
  "python_version": ">=3.10",
  "entrypoints": {
    "engine_cli": "scripts/pipeline_engine.py",
    "r10_validator_cli": "scripts/validate_r10a.py",
    "import": "from pipeline_engine import PipelineEngine"
  },
  "r10_plugins": [
    "r10_plugins.base_plugin.R10Plugin",
    "r10_plugins.passthrough.PassthroughPlugin",
    "r10_plugins.numeric_factsheet.NumericFactsheetPlugin"
  ],
  "templates": [
    "templates/CONTRACT-00-template.md",
    "templates/CONTRACT-00-addendum-sync-template.md",
    "templates/ORCHESTRATOR-RUNBOOK-template.md",
    "templates/spawn-matrix-template.md",
    "templates/version-brief-template.md"
  ]
}
